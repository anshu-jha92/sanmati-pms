# ============================================================================
# Sanmati PMS — Backend environment template.
# Copy to `.env` and fill in real values:  cp .env.example .env
# NEVER commit the real .env (it is gitignored). Validation lives in
# src/config/env.js — the server refuses to boot on invalid/missing values.
# ============================================================================

# ===== App =====
NODE_ENV=production            # development | production | test
PORT=4000
LOG_LEVEL=info                 # trace|debug|info|warn|error|fatal — use info/warn in prod
# Comma-separated allowed origins. Use the real site origin in prod.
# (Same-origin deploy behind Apache barely uses CORS, but keep it correct.)
CORS_ORIGIN=https://sanmati.itsybizz.com

# ===== MongoDB =====
# Atlas:  mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/sanmati?retryWrites=true&w=majority
# Local:  mongodb://localhost:27017/sanmati
MONGODB_URI=
MONGODB_POOL_SIZE=20

# ===== Redis (required: cache, queues, rate-limit, Socket.IO adapter) =====
# rediss://default:PASSWORD@host:6379  (TLS)   |   redis://127.0.0.1:6379  (local)
REDIS_URL=
REDIS_KEY_PREFIX=pa:

# ===== Auth (secrets MUST be >= 32 chars; generate, never reuse) =====
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_HEX_CHARS_MINIMUM
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_HEX_CHARS_MINIMUM
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ===== IoT Ingestion =====
IOT_MAX_PAYLOAD_BYTES=65536
IOT_RATE_LIMIT_RPS=50
# IOT_HMAC_SECRET — reserved; HMAC payload verification is NOT implemented yet.
#   Leave unset; setting it does nothing today.

# ===== Integration API =====
# Shared key 3rd-party systems use to push sales/purchase orders (X-API-Key).
# When set it must be a long random value. Keep secret.
INTEGRATION_API_KEY=
# ERP_BASE_URL / ERP_API_KEY / ERP_SYNC_INTERVAL_MINUTES — not wired in code yet.

# ===== Workers =====
# Run background workers inside the API process (recommended single-service).
# Set to false only if you run a dedicated `npm run worker` process.
WORKERS_INLINE=true
WORKER_CONCURRENCY_TELEMETRY=8
WORKER_CONCURRENCY_OEE=2
WORKER_CONCURRENCY_SYNC=2

# ===== Super Admin bootstrap (created on first boot ONLY if ADMIN_CREATE_ON_BOOT=true) =====
ADMIN_CREATE_ON_BOOT=false
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NAME="System Admin"
ADMIN_EMPLOYEE_CODE=ADMIN
